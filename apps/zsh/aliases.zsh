alias ls="ls -al --color"
alias la="ls -al"
alias vim="nvim"
alias gs="git status"
# alias cd="z"
alias ..="cd .."
alias ...="cd ../.."
alias c="clear"
alias code="agy"

# Aliases for DDEV
alias ds="ddev start && ddev ssh"
alias dsr="ddev restart"
alias dss="ddev ssh"
alias ds!="ddev stop"
alias dsp="ddev poweroff"

# ZSH / OMZ Aliases
alias config_zsh="code ~/.zshrc"
alias config_zsh_all="code ~/.config"
alias config_starship="code ~/.config/starship.toml"